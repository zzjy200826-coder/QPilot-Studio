{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/server",
    "rootDir": "src",
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["src/server/**/*.ts", "src/domain/**/*.ts", "src/browser/**/*.ts"]
}
