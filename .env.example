# Runtime server
HOST=0.0.0.0
PORT=8787
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=./data/qpilot.db
ARTIFACTS_DIR=./data/artifacts
REPORTS_DIR=./data/reports
SESSIONS_DIR=./data/sessions
PLANNER_CACHE_DIR=./data/planner-cache
PLATFORM_POSTGRES_URL=postgres://qpilot:qpilot@localhost:5432/qpilot_platform
PLATFORM_REDIS_URL=redis://localhost:6379
PLATFORM_REDIS_QUEUE_NAME=platform-load-runs
PLATFORM_REDIS_WORKER_ENABLED=true
PLATFORM_REDIS_WORKER_CONCURRENCY=2
PLATFORM_REDIS_JOB_ATTEMPTS=3
PLATFORM_REDIS_JOB_BACKOFF_MS=1500
PLATFORM_WORKER_HEARTBEAT_INTERVAL_MS=3000
PLATFORM_WORKER_HEARTBEAT_TIMEOUT_MS=15000
PLATFORM_PROMETHEUS_URL=http://localhost:9090
PLATFORM_METRICS_ENABLED=true
METRICS_BEARER_TOKEN=replace_with_a_long_random_token
AUTH_SELF_SERVICE_REGISTRATION=false
AUTH_ALLOWED_EMAILS=you@example.com
OPS_ALERTS_ENABLED=false
OPS_ALERT_WEBHOOK_URL=https://example.com/qpilot-ops-webhook
OPS_ALERT_POLL_INTERVAL_MS=30000
OPS_ALERT_COOLDOWN_MS=600000
OPS_QUEUE_BACKLOG_WARN_THRESHOLD=5
OPS_RELEASE_HOLD_LOOKBACK_MINUTES=1440
BACKUP_SHARED_ROOT=./data
BACKUP_OPS_ROOT=./ops
BACKUP_S3_ENDPOINT=https://s3.example.com
BACKUP_S3_REGION=us-east-1
BACKUP_S3_BUCKET=qpilot-backups
BACKUP_S3_PREFIX=backups
BACKUP_S3_ACCESS_KEY_ID=replace_with_access_key
BACKUP_S3_SECRET_ACCESS_KEY=replace_with_secret_key
BACKUP_S3_FORCE_PATH_STYLE=false
BACKUP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
BACKUP_RETENTION_DAYS=14
BACKUP_STALE_AFTER_HOURS=36

# OpenAI-compatible endpoint
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=90000

# 32-byte key encoded as 64-char hex
CREDENTIAL_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Web app runtime API base
VITE_RUNTIME_BASE_URL=http://localhost:8787

# Public/private host split. deploy scripts usually derive these automatically.
VITE_AUTH_SELF_SERVICE_REGISTRATION=false
VITE_PRIVATE_APP_ORIGIN=http://localhost:5173
VITE_PUBLIC_MARKETING_HOST=www.example.com

# Owner bootstrap: inject this only when running:
# pnpm auth:bootstrap-owner -- --email you@example.com --display-name "Your Name" --tenant-name "Private Workspace"
# Do not keep it in the long-lived production runtime env.
# AUTH_BOOTSTRAP_OWNER_PASSWORD=replace_with_a_temporary_bootstrap_password
