{
  "name": "@qpilot/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --loader ts-node/esm src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "node --loader ts-node/esm src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke:bullmq": "node --loader ts-node/esm src/scripts/platform-bullmq-smoke.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "node --loader ts-node/esm src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.1",
    "@fastify/websocket": "^11.0.2",
    "@libsql/client": "^0.15.15",
    "@qpilot/ai-gateway": "workspace:*",
    "@qpilot/prompt-packs": "workspace:*",
    "@qpilot/report-core": "workspace:*",
    "@qpilot/shared": "workspace:*",
    "bullmq": "^5.74.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.41.0",
    "fastify": "^5.2.1",
    "ioredis": "^5.10.1",
    "nanoid": "^5.1.5",
    "playwright": "^1.52.0",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3"
  }
}
