{
  "name": "@qpilot/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit --pretty false",
    "test": "vitest run --passWithNoTests",
    "test:e2e:console-review": "node --experimental-strip-types e2e/console-review.e2e.ts",
    "test:e2e:load-platform": "node --experimental-strip-types e2e/load-platform.e2e.ts",
    "test:e2e:release-gates": "node --experimental-strip-types e2e/release-gates.e2e.ts",
    "test:e2e:backups": "node --experimental-strip-types e2e/backups.e2e.ts",
    "test:e2e": "pnpm run test:e2e:console-review && pnpm run test:e2e:load-platform && pnpm run test:e2e:release-gates && pnpm run test:e2e:backups"
  },
  "dependencies": {
    "@qpilot/shared": "workspace:*",
    "@tanstack/react-query": "^5.68.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "vite": "^6.3.2"
  }
}
